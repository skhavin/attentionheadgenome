---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Head Explorer" description="Browse all 1,568 attention heads across four architectures. Filter by class, verify the taxonomy yourself.">

<div class="explorer-header">
  <p class="eyebrow">Interactive</p>
  <h1>Head Geometry Explorer</h1>
  <p class="lead">
    A 3D PCA projection of the KV-cache Key vectors for every attention head — across GPT-2,
    Qwen-0.5B, Qwen-1.5B, and Llama-3.2-1B. Filter by functional class. Rotate. Verify.
  </p>
  <p class="lead" style="margin-top:.5rem; font-size:.9rem">
    This is the anti-cherry-picking guarantee: all 1,568 heads, fully browsable.
  </p>
</div>

<!-- Full-viewport iframe embedding the self-contained KV viewer -->
<div class="iframe-wrap">
  <iframe
    src={`${base}/kv-explorer.html`}
    title="Interactive KV Cache Geometry Explorer"
    class="explorer-iframe"
    loading="lazy"
    allow="fullscreen"
  ></iframe>
</div>

</Layout>

<style>
.explorer-header {
  padding: 10rem 2.5rem 3rem;
  max-width: 700px; margin: 0 auto; text-align: center;
}
.explorer-header h1 {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 200; letter-spacing: -.04em; margin-bottom: 1.25rem; line-height: 1.1;
}
.lead { color: var(--text-2); font-weight: 300; line-height: 1.65; }
.iframe-wrap {
  width: 100%; padding: 0 1.5rem 4rem;
}
.explorer-iframe {
  width: 100%; height: 90vh;
  border: 1px solid var(--border); border-radius: var(--radius);
  background: var(--bg2); display: block;
  box-shadow: var(--shadow-md);
}
</style>
