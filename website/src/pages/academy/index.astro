---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
---

<AcademyLayout title="Visual Roadmap">
  
  <div class="roadmap-header">
    <h1 class="hero-title reveal">HeadGenome Academy</h1>
    <p class="hero-sub reveal">
      The interactive research handbook. Follow the path from absolute basics to state-of-the-art transformer discoveries.
    </p>
  </div>

  <div class="roadmap-container reveal">
    
    <div class="roadmap-line"></div>

    <!-- Section 1 -->
    <div class="roadmap-section">
      <div class="roadmap-badge" style="color: var(--local); border-color: rgba(44,82,130,0.3); background: rgba(44,82,130,0.1);">
        Foundations
      </div>
      
      <div class="roadmap-nodes">
        <a href="/attentionheadgenome/academy/part1-fundamentals" class="roadmap-node left">
          <div class="node-content">
            <span class="node-num">01</span>
            <h3>LLMs & Tokens</h3>
          </div>
          <div class="node-anchor"></div>
        </a>
        
        <a href="/attentionheadgenome/academy/part1-fundamentals" class="roadmap-node right">
          <div class="node-anchor"></div>
          <div class="node-content">
            <span class="node-num">02</span>
            <h3>Embeddings & Position</h3>
          </div>
        </a>
        
        <a href="/attentionheadgenome/academy/part2-attention-mechanics" class="roadmap-node left">
          <div class="node-content">
            <span class="node-num">03</span>
            <h3>Attention & Softmax</h3>
          </div>
          <div class="node-anchor"></div>
        </a>
        
        <a href="/attentionheadgenome/academy/part3-math-foundations" class="roadmap-node right">
          <div class="node-anchor"></div>
          <div class="node-content">
            <span class="node-num">04</span>
            <h3>Entropy & Math Tools</h3>
          </div>
        </a>
      </div>
    </div>

    <!-- Section 2 -->
    <div class="roadmap-section">
      <div class="roadmap-badge" style="color: var(--retrieval); border-color: rgba(107,70,193,0.3); background: rgba(107,70,193,0.1);">
        HeadGenome Taxonomy
      </div>
      
      <div class="roadmap-nodes">
        <a href="/attentionheadgenome/academy/part4-head-species" class="roadmap-node left">
          <div class="node-content">
            <span class="node-num">05</span>
            <h3>Sink Heads</h3>
          </div>
          <div class="node-anchor"></div>
        </a>
        
        <a href="/attentionheadgenome/academy/part4-head-species" class="roadmap-node right">
          <div class="node-anchor"></div>
          <div class="node-content">
            <span class="node-num">06</span>
            <h3>Local Heads</h3>
          </div>
        </a>
        
        <a href="/attentionheadgenome/academy/part4-head-species" class="roadmap-node left">
          <div class="node-content">
            <span class="node-num">07</span>
            <h3>Retrieval Heads</h3>
          </div>
          <div class="node-anchor"></div>
        </a>
        
        <a href="/attentionheadgenome/academy/part4-head-species" class="roadmap-node right">
          <div class="node-anchor"></div>
          <div class="node-content">
            <span class="node-num">08</span>
            <h3>Induction Heads</h3>
          </div>
        </a>
      </div>
    </div>

    <!-- Section 3 -->
    <div class="roadmap-section" style="margin-bottom: 0;">
      <div class="roadmap-badge" style="color: #34d399; border-color: rgba(52,211,153,0.3); background: rgba(52,211,153,0.1);">
        Discoveries & Systems
      </div>
      
      <div class="roadmap-nodes">
        <a href="/attentionheadgenome/academy/part5-experimental-findings" class="roadmap-node left">
          <div class="node-content">
            <span class="node-num">09</span>
            <h3>The V/Q Law & Co-Gating</h3>
          </div>
          <div class="node-anchor"></div>
        </a>
        
        <a href="/attentionheadgenome/academy/part6-systems-engineering" class="roadmap-node right">
          <div class="node-anchor"></div>
          <div class="node-content">
            <span class="node-num">10</span>
            <h3>KV Cache Routing</h3>
          </div>
        </a>
        
        <a href="/attentionheadgenome/academy/part7-architecture-differences" class="roadmap-node left">
          <div class="node-content">
            <span class="node-num">11</span>
            <h3>Architecture Differences</h3>
          </div>
          <div class="node-anchor"></div>
        </a>
      </div>
    </div>

  </div>

</AcademyLayout>

<style>
  .roadmap-header {
    text-align: center;
    margin-bottom: 5rem;
  }
  .roadmap-header .hero-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin-bottom: 1rem;
  }
  
  .roadmap-container {
    position: relative;
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  
  .roadmap-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--local) 0%, var(--retrieval) 50%, #34d399 100%);
    transform: translateX(-50%);
    opacity: 0.3;
    z-index: 0;
  }
  
  .roadmap-section {
    position: relative;
    z-index: 10;
    margin-bottom: 6rem;
  }
  
  .roadmap-badge {
    display: inline-block;
    padding: 0.3rem 1.2rem;
    border-radius: 2rem;
    border: 1px solid;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--bg);
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 4rem;
    box-shadow: var(--shadow-sm);
  }
  
  .roadmap-nodes {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  
  .roadmap-node {
    display: flex;
    align-items: center;
    width: 100%;
    text-decoration: none;
    position: relative;
  }
  
  .roadmap-node.left {
    justify-content: flex-end;
    padding-right: 50%;
  }
  .roadmap-node.right {
    justify-content: flex-start;
    padding-left: 50%;
  }
  
  .node-content {
    background: var(--bg2);
    border: 1px solid var(--border-med);
    border-radius: var(--radius-sm);
    padding: 1rem 1.5rem;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-xs);
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 240px;
  }
  .roadmap-node.left .node-content {
    margin-right: 20px;
  }
  .roadmap-node.right .node-content {
    margin-left: 20px;
  }
  
  .node-num {
    font-size: 0.75rem;
    font-family: var(--mono);
    color: var(--accent);
    font-weight: 600;
    opacity: 0.8;
  }
  
  .roadmap-node:hover .node-content {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--surface);
    box-shadow: var(--shadow-md);
  }
  
  .node-content h3 {
    margin: 0 !important;
    font-size: 0.95rem !important;
    font-weight: 500 !important;
    color: var(--text) !important;
    transition: color 0.2s;
  }
  
  .roadmap-node:hover h3 {
    color: var(--accent) !important;
  }
  
  .node-anchor {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    background: var(--bg);
    border: 2px solid var(--border-med);
    border-radius: 50%;
    z-index: 2;
    transition: all 0.3s ease;
  }
  
  .roadmap-node:hover .node-anchor {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  /* Connecting lines from node to center */
  .roadmap-node::before {
    content: '';
    position: absolute;
    top: 50%;
    width: 20px;
    height: 1px;
    background: var(--border-med);
    z-index: 1;
    transition: background 0.3s;
  }
  .roadmap-node.left::before {
    right: 50%;
  }
  .roadmap-node.right::before {
    left: 50%;
  }
  .roadmap-node:hover::before {
    background: var(--accent);
  }
</style>
