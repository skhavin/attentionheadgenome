---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Paper & Code" description="Open science. All code, data, and artefacts are publicly available.">
<div class="page-top">
  <p class="eyebrow">Paper, Code & Citation</p>
  <h1>Open science,<br/>reproducible results.</h1>
  <p class="lead">All code, data, and trained artefacts are publicly available. Every figure can be reproduced from the provided scripts.</p>
</div>

<div class="section">
  <div class="resource-list reveal">
    <a href="https://github.com/skhavin/attentionheadgenome" target="_blank" rel="noopener" class="resource-item">
      <div class="resource-meta">
        <span class="resource-type">Repository</span>
        <span class="resource-arrow">↗</span>
      </div>
      <div class="resource-title">github.com/skhavin/attentionheadgenome</div>
      <p>Full source code, phase scripts, and reproducibility instructions</p>
    </a>
    <a href={`${base}/report`} class="resource-item">
      <div class="resource-meta">
        <span class="resource-type">Report</span>
        <span class="resource-arrow">→</span>
      </div>
      <div class="resource-title">HeadGenome Master Report</div>
      <p>Full technical write-up with all sections, figures, and analysis</p>
    </a>
    <a href={`${base}/explorer`} class="resource-item">
      <div class="resource-meta">
        <span class="resource-type">Interactive</span>
        <span class="resource-arrow">→</span>
      </div>
      <div class="resource-title">Head Explorer</div>
      <p>3D PCA geometry for all 1,568 heads — filter by model and class</p>
    </a>
    <a href="https://github.com/skhavin/attentionheadgenome/blob/master/outputs/canonical_labels.json" target="_blank" rel="noopener" class="resource-item">
      <div class="resource-meta">
        <span class="resource-type">Data</span>
        <span class="resource-arrow">↗</span>
      </div>
      <div class="resource-title">canonical_labels.json</div>
      <p>Machine-readable head taxonomy for all 1,568 heads with entropy scores</p>
    </a>
  </div>

  <hr/>

  <h2 class="reveal">Reproduce the results</h2>
  <div class="code-block reveal">
    <pre>git clone https://github.com/skhavin/attentionheadgenome
cd attentionheadgenome

# Phase 1: generate head taxonomy
python phase1/step1_generate_index.py

# Generate all figures
python scripts/visualize_kv_geometry.py
python scripts/compute_speedup_curves.py</pre>
  </div>

  <hr/>

  <h2 class="reveal">BibTeX</h2>
  <div class="code-block reveal">
    <pre set:html={`@article&#123;khavin2025headgenome,\n  title  = &#123;HeadGenome: A Universal Taxonomy of Attention Heads&#125;,\n  author = &#123;Khavin, S.&#125;,\n  year   = &#123;2025&#125;,\n  note   = &#123;https://github.com/skhavin/attentionheadgenome&#125;,\n&#125;`}></pre>
  </div>

  <hr/>

  <h2 class="reveal">Key results</h2>
  <div class="reveal">
    <table class="data-table">
      <thead><tr><th>Result</th><th>Value</th><th>Type</th></tr></thead>
      <tbody>
        <tr><td>Total heads classified</td><td>1,568</td><td><span class="badge badge-measured">Measured</span></td></tr>
        <tr><td>V/Q scaling law p-value</td><td>1.92 × 10⁻¹²⁷</td><td><span class="badge badge-measured">Measured</span></td></tr>
        <tr><td>Co-ablation recovery</td><td>96.5%</td><td><span class="badge badge-measured">Measured</span></td></tr>
        <tr><td>KV-cache compression (Llama-3.2-1B)</td><td>13.3×</td><td><span class="badge badge-measured">Measured</span></td></tr>
        <tr><td>FLOP savings @ N=4K</td><td>3.9–4.4×</td><td><span class="badge badge-projected">Projected</span></td></tr>
        <tr><td>FLOP savings @ N=32K</td><td>6.1–7.7×</td><td><span class="badge badge-projected">Projected</span></td></tr>
      </tbody>
    </table>
  </div>
</div>
</Layout>

<style>
.section { max-width:820px; margin:0 auto; padding:3rem 2.5rem 8rem; }
.section h2 { font-size:clamp(1.5rem,3vw,2.2rem); font-weight:200; letter-spacing:-.04em; line-height:1.15; margin-bottom:1.25rem; }
.resource-list { display:flex; flex-direction:column; border-top: 1px solid var(--border); }
.resource-item {
  padding: 2rem 0; border-bottom: 1px solid var(--border);
  text-decoration: none; color: var(--text); display: block;
  transition: opacity .2s;
}
.resource-item:hover { opacity: .7; }
.resource-meta { display:flex; justify-content:space-between; margin-bottom:.4rem; }
.resource-type { font-size:.7rem; font-weight:500; letter-spacing:.08em; text-transform:uppercase; color:var(--text-3); }
.resource-arrow { font-size:.9rem; color:var(--text-3); }
.resource-title { font-size:1.05rem; font-weight:400; letter-spacing:-.02em; margin-bottom:.35rem; }
.resource-item p { font-size:.85rem; color:var(--text-3); font-weight:300; margin:0; }
.code-block {
  background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-sm);
  padding: 1.75rem 2rem; margin: 1.5rem 0;
}
.code-block pre {
  font-family: var(--mono); font-size: .82rem; line-height: 1.9;
  color: var(--text-2); margin: 0; white-space: pre-wrap;
}
</style>
