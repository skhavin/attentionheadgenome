---
// Layout.astro - shared layout for all pages
const { title = 'HeadGenome', description = 'Mapping what every attention head does.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} · HeadGenome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href={`${base}/styles/global.css`} />
</head>
<body>
  <nav class="nav" id="nav">
    <a href={`${base}/`} class="nav-logo">HeadGenome</a>
    <div class="nav-links">
      <a href={`${base}/taxonomy`}>Taxonomy</a>
      <a href={`${base}/universality`}>Universality</a>
      <a href={`${base}/causal`}>Causal</a>
      <a href={`${base}/systems`}>Systems</a>
      <a href={`${base}/explorer`}>Explorer</a>
      <a href={`${base}/limitations`}>Limits</a>
      <a href={`${base}/paper`} class="nav-cta">Paper ↗</a>
    </div>
    <button class="theme-btn" id="theme-btn" aria-label="Toggle theme">☀</button>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <p>HeadGenome · Attention Head Taxonomy Research · 2025</p>
    <p>
      <a href="https://github.com/skhavin/attentionheadgenome" target="_blank">GitHub</a> ·
      <a href={`${base}/paper`}>Paper</a> ·
      <a href={`${base}/explorer`}>Explorer</a>
    </p>
  </footer>

  <script>
    // Scroll-based nav opacity
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav-scrolled', window.scrollY > 40);
    }, { passive: true });

    // Theme toggle
    const btn = document.getElementById('theme-btn');
    const html = document.documentElement;
    btn?.addEventListener('click', () => {
      const isDark = html.getAttribute('data-theme') === 'dark';
      html.setAttribute('data-theme', isDark ? 'light' : 'dark');
      btn.textContent = isDark ? '🌙' : '☀';
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    });
    // restore
    const saved = localStorage.getItem('theme');
    if (saved) {
      html.setAttribute('data-theme', saved);
      if (btn) btn.textContent = saved === 'dark' ? '☀' : '🌙';
    }

    // Intersection Observer for reveal animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
