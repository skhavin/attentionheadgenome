---
const { title = 'HeadGenome', description = 'Mapping what every attention head does.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} · HeadGenome</title>
  <link rel="stylesheet" href={`${base}/styles/global.css`} />
</head>
<body>
  <nav class="nav" id="nav">
    <a href={`${base}/`} class="nav-logo">HeadGenome</a>
    <div class="nav-links">
      <a href={`${base}/taxonomy`}>Taxonomy</a>
      <a href={`${base}/universality`}>Universality</a>
      <a href={`${base}/causal`}>Causal</a>
      <a href={`${base}/systems`}>Systems</a>
      <a href={`${base}/explorer`}>Explorer</a>
      <a href={`${base}/report`}>Report</a>
      <a href={`${base}/limitations`}>Limitations</a>
    </div>
    <div class="nav-end">
      <a href={`${base}/paper`} class="nav-cta">Paper</a>
      <button class="theme-btn" id="theme-btn" aria-label="Toggle theme">○</button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <p>The HeadGenome Project · 2025</p>
    <p>
      <a href="https://github.com/skhavin/attentionheadgenome" target="_blank" rel="noopener">GitHub</a>
      &nbsp;·&nbsp;
      <a href={`${base}/report`}>Report</a>
      &nbsp;·&nbsp;
      <a href={`${base}/explorer`}>Explorer</a>
      &nbsp;·&nbsp;
      <a href={`${base}/limitations`}>Limitations</a>
    </p>
  </footer>

  <script>
    // Nav transparency
    const nav = document.getElementById('nav');
    const onScroll = () => nav?.classList.toggle('nav-scrolled', window.scrollY > 20);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Theme toggle
    const btn = document.getElementById('theme-btn');
    const html = document.documentElement;
    function applyTheme(t: string) {
      html.setAttribute('data-theme', t);
      if (btn) btn.textContent = t === 'dark' ? '○' : '●';
      localStorage.setItem('hg-theme', t);
    }
    btn?.addEventListener('click', () => {
      applyTheme(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
    });
    const saved = localStorage.getItem('hg-theme');
    if (saved) applyTheme(saved);

    // Intersection reveal
    const obs = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  </script>
</body>
</html>
