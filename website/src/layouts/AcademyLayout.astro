---
import Layout from './Layout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  frontmatter?: {
    title: string;
  };
}

const title = Astro.props.title || Astro.props.frontmatter?.title || 'HeadGenome Academy';
---

<Layout title={title}>
  <div style="display: flex; min-height: calc(100vh - 52px); margin-top: 52px; position: relative;">
    <Sidebar />
    
    <main style="flex: 1; min-width: 0;">
      <div class="academy-content">
        <slot />
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  .academy-content {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2.5rem 8rem;
  }
  .academy-content h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 200;
    letter-spacing: -.04em;
    line-height: 1.12;
    margin-bottom: 1.5rem;
  }
  .academy-content h2 {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 200;
    letter-spacing: -.03em;
    line-height: 1.15;
    margin: 4rem 0 1.5rem;
  }
  .academy-content h3 {
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -.02em;
    margin: 2.5rem 0 1rem;
  }
  .academy-content p {
    color: var(--text-2);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .academy-content p.lead {
    font-size: 1.2rem;
    color: var(--text-2);
    font-weight: 300;
    max-width: 650px;
    line-height: 1.65;
    margin-bottom: 3rem;
  }
  .academy-content strong {
    font-weight: 500;
    color: var(--text);
  }
  .academy-content ul, .academy-content ol {
    color: var(--text-2);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .academy-content li {
    margin-bottom: 0.5rem;
  }
  .academy-content code {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--bg2);
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--accent);
  }
</style>
